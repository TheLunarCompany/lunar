# OIDC provider JWKS endpoint for token verification
JWKS_URI=https://your-issuer.example.com/.well-known/jwks.json

# Expected JWT issuer (must match the "iss" claim in the token)
JWT_ISSUER=https://your-issuer.example.com

# Expected JWT audience (must match the "aud" claim in the token)
JWT_AUDIENCE=your-audience

# Server port (optional, defaults to 4050)
# PORT=4050
