ENABLE_CONTROL_PLANE_STREAMING=true
ENABLE_CONTROL_PLANE_REST=true
DIND_ENABLED=false
# When false, stdio MCP servers are not allowed (UI add rejected, spawn blocked).
ENABLE_STDIO_MCP_SERVERS=true
SERVE_METRICS_PORT=9002
MCPX_PORT=9000
VERSION=0.0.0
INSTANCE_ID=INSTANCE_ID
CONTROL_PLANE_APP_CONFIG_USE_NEXT_VERSION=true
CONTROL_PLANE_APP_CONFIG_KEEP_DISCRIMINATING_TAGS=true
